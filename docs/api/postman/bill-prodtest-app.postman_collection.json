  },
  "item": [
    {
      "name": "GET Soft Pull Metadata",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/credit/softpull",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "credit",
            "softpull"
          ]
        }
      }
    },
    {
