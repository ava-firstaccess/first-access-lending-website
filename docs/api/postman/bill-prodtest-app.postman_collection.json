          "raw": "{\n  \"mode\": \"production-test\",\n  \"borrower\": {\n    \"firstName\": \"Bill\",\n    \"middleName\": \"C\",\n    \"lastName\": \"Testcase\",\n    \"suffixName\": \"JR\",\n    \"ssn\": \"000000015\",\n    \"address\": \"8842 48th Ave\",\n    \"city\": \"Anthill\",\n    \"state\": \"MO\",\n    \"zip\": \"65488\",\n    \"preferredResponseFormat\": \"Html\"\n  }\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/credit/softpull",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "credit",
            "softpull"
          ]
